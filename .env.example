# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./studvisor.db

# ─── SECURITY ───────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_very_long_random_hex_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI SERVICES ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Fallback to Mock AI if key is empty

# ─── SEED DATA ──────────────────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=admin123
SEED_FACULTY_PASSWORD=faculty123
SEED_STUDENT_PASSWORD=student123

# ─── ENVIRONMENT ────────────────────────────────────────────────────────────
ENV=development
DEBUG=true
